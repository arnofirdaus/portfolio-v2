---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import DisplayHeadline from "../components/DisplayHeadline.astro";
import MetadataLabel from "../components/MetadataLabel.astro";
import DarkCTAPanel from "../components/DarkCTAPanel.astro";
import ProjectCard from "../components/ProjectCard.astro";
import OutlinedTag from "../components/OutlinedTag.astro";
import CTALinkRow from "../components/CTALinkRow.astro";
import { getCollection } from "astro:content";
import HairlineDivider from "../components/HairlineDivider.astro";

const projects = await getCollection("projects");
projects.sort((a, b) =>
  b.data.date.toString().localeCompare(a.data.date.toString()),
);

const experience = await getCollection("experience");
experience.sort((a, b) =>
  b.data.startDate.toString().localeCompare(a.data.startDate.toString()),
);

const categorizedSkills = [
  {
    category: "Frontend",
    items: ["React", "Next.js", "Vue.js", "Nuxt.js", "TailwindCSS"],
  },
  {
    category: "Languages & Mobile",
    items: ["TypeScript", "PHP", "Flutter", "React Native", "Electron"],
  },
  {
    category: "Backend & Database",
    items: ["Firebase", "SQLite", "Mirage.js", "CodeIgniter"],
  },
];
---

<Layout title="Arno Firdaus | Software Engineer">
  <Section theme="bone" class="pt-24 pb-32 px-6 md:px-10">
    <div class="max-w-[1200px] mx-auto">
      <DisplayHeadline as="h1"
        >Arno Firdaus<br />Software Engineer</DisplayHeadline
      >
      <div class="mt-8">
        <MetadataLabel
          >Senior Frontend Engineer — React/Next.js Specialist | Full-Stack &
          Mobile Development</MetadataLabel
        >
      </div>
    </div>
  </Section>

  <DarkCTAPanel />

  <Section
    id="about"
    theme="bone"
    class="py-32 px-6 md:px-10 border-t border-(--color-border)"
  >
    <div class="max-w-[1200px] mx-auto">
      <div class="mb-16">
        <DisplayHeadline as="h2">Experience</DisplayHeadline>
      </div>
      <div class="border-t border-(--color-border) mb-24">
        {
          experience.map((exp) => (
            <div class="grid grid-cols-1 md:grid-cols-12 border-b border-(--color-border) py-8 gap-6">
              <div class="md:col-span-4 flex flex-col gap-1">
                <MetadataLabel>{exp.data.company}</MetadataLabel>
                <MetadataLabel class="text-color-graphite">
                  {exp.data.startDate} — {exp.data.endDate || "PRESENT"}
                </MetadataLabel>
              </div>
              <div class="md:col-span-8">
                <h3 class="font-display font-[520] text-subheading leading-[1.15] tracking-[-0.2px] text-color-text mb-4">
                  {exp.data.title}
                </h3>
                <p class="font-sans text-body leading-[1.4] tracking-[0.14px] text-color-text max-w-[600px]">
                  {exp.data.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mb-16">
        <DisplayHeadline as="h2">Technologies</DisplayHeadline>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {
          categorizedSkills.map((group) => (
            <div>
              <MetadataLabel class="mb-6 block text-color-text">
                {group.category}
              </MetadataLabel>
              <div class="flex flex-wrap gap-[10px]">
                {group.items.map((skill) => (
                  <OutlinedTag>{skill}</OutlinedTag>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Section>
  <HairlineDivider />

  <Section id="work" class="py-32 px-6 md:px-10">
    <div class="max-w-[1200px] mx-auto">
      <div class="mb-16">
        <DisplayHeadline as="h2">My Work</DisplayHeadline>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-16">
        {
          projects.map((p) => (
            <ProjectCard
              title={p.data.title}
              category={p.data.category}
              slug={p.id}
              techStack={p.data.techStack}
              thumbnail={p.data.thumbnail}
            />
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="contact" theme="obsidian" class="w-full px-6 md:px-10 py-32">
    <div
      class="max-w-[1200px] mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-16"
    >
      <div>
        <DisplayHeadline>Let's Work<br />Together</DisplayHeadline>
      </div>
      <div class="flex flex-col border-t border-(--color-border)">
        <CTALinkRow href="mailto:ruaz.arno@gmail.com">Email Me</CTALinkRow>
        <CTALinkRow
          href="https://linkedin.com/in/arno-firdaus"
          target="_blank"
          rel="noopener noreferrer">LinkedIn</CTALinkRow
        >
        <CTALinkRow
          href="https://github.com/arnofirdaus"
          target="_blank"
          rel="noopener noreferrer">GitHub</CTALinkRow
        >
      </div>
    </div>
  </Section>
</Layout>
