---
import MetadataLabel from "./MetadataLabel.astro";
---

<header
  class="theme-bone w-full h-16 px-6 md:px-10 flex items-center justify-between sticky top-0 z-50 border-b border-(--color-border)"
>
  <a
    href={`${import.meta.env.BASE_URL}`}
    class="flex items-center gap-2 overflow-hidden h-full"
  >
    <div
      id="nav-dynamic-title"
      class="h-full flex items-center transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-full opacity-0"
    >
      <MetadataLabel>ARNO FIRDAUS — SOFTWARE ENGINEER</MetadataLabel>
    </div>
  </a>

  <div class="hidden md:flex items-center gap-8">
    <a href="#about"><MetadataLabel>EXPERIENCE</MetadataLabel></a>
    <a href="#work"><MetadataLabel>PROJECTS</MetadataLabel></a>
    <a href="#contact"><MetadataLabel>CONTACT</MetadataLabel></a>
  </div>

  <button id="mobile-menu-btn" class="md:hidden text-color-text focus:outline-none flex items-center justify-center">
    <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <svg id="close-icon" class="hidden w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</header>

<div
  id="mobile-menu"
  class="hidden fixed inset-0 theme-obsidian z-40 flex-col pt-24 px-6"
>
  <nav class="flex flex-col">
    <a
      href={`${import.meta.env.BASE_URL}/#about`}
      class="mobile-nav-link border-b border-(--color-border) py-4"
      ><MetadataLabel>EXPERIENCE</MetadataLabel></a
    >
    <a
      href={`${import.meta.env.BASE_URL}/#work`}
      class="mobile-nav-link border-b border-(--color-border) py-4"
      ><MetadataLabel>PROJECTS</MetadataLabel></a
    >
    <a
      href={`${import.meta.env.BASE_URL}/#contact`}
      class="mobile-nav-link border-b border-(--color-border) py-4"
      ><MetadataLabel>CONTACT</MetadataLabel></a
    >
  </nav>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  const toggleMenu = () => {
    menu?.classList.toggle("hidden");
    const isHidden = menu?.classList.contains("hidden");
    
    if (isHidden) {
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    } else {
      hamburgerIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
    }
  };

  btn?.addEventListener("click", toggleMenu);

  // Close menu when clicking a link
  mobileLinks.forEach((link) => {
    link.addEventListener("click", toggleMenu);
  });

  // Dynamic Scroll Title Logic
  const dynamicTitle = document.getElementById("nav-dynamic-title");

  // Show title immediately on project detail pages (which aren't the root "/")
  const isHomePage =
    window.location.pathname === import.meta.env.BASE_URL ||
    window.location.pathname === `${import.meta.env.BASE_URL}/` ||
    window.location.pathname === "/index.html";

  if (!isHomePage && dynamicTitle) {
    dynamicTitle.classList.remove("translate-y-full", "opacity-0");
    dynamicTitle.classList.add("translate-y-0", "opacity-100");
  } else if (isHomePage && dynamicTitle) {
    // Initial check in case page is reloaded halfway down
    if (window.scrollY > 150) {
      dynamicTitle.classList.remove("translate-y-full", "opacity-0");
      dynamicTitle.classList.add("translate-y-0", "opacity-100");
    }

    window.addEventListener(
      "scroll",
      () => {
        // Threshold is roughly when the main hero headline scrolls out of view (~150px)
        if (window.scrollY > 150) {
          dynamicTitle.classList.remove("translate-y-full", "opacity-0");
          dynamicTitle.classList.add("translate-y-0", "opacity-100");
        } else {
          dynamicTitle.classList.add("translate-y-full", "opacity-0");
          dynamicTitle.classList.remove("translate-y-0", "opacity-100");
        }
      },
      { passive: true },
    );
  }
</script>
