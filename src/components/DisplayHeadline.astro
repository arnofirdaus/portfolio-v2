---
interface Props {
  as?: "h1" | "h2" | "h3" | "h4";
  class?: string;
}
const { as: Tag = "h2", class: className } = Astro.props;
---

<Tag
  class={`font-display font-[520] text-display md:text-display-lg leading-[0.98] tracking-[-0.02em] text-color-text ${className || ""}`}
>
  <slot />
</Tag>
