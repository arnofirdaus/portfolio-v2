---
import DisplayHeadline from "./DisplayHeadline.astro";
import CTALinkRow from "./CTALinkRow.astro";
---

<section
  class="theme-obsidian w-full px-6 md:px-10 py-20 md:py-32 scroll-mt-16"
>
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
    <div>
      <DisplayHeadline>Let's Work<br />Together</DisplayHeadline>
    </div>
    <div class="flex flex-col border-t border-(--color-border)">
      <CTALinkRow href="#about">About Me</CTALinkRow>
      <CTALinkRow href="#work">View Work</CTALinkRow>
      <CTALinkRow href="#contact">Get In Touch</CTALinkRow>
    </div>
  </div>
</section>
